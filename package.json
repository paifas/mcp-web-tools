{
  "name": "mcp-web-tools",
  "version": "0.6.4",
  "description": "MCP server providing web search tools for AI assistants",
  "type": "module",
  "main": "build/index.js",
  "bin": {
    "mcp-web-tools": "./build/index.js"
  },
  "files": [
    "build",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc && chmod 755 build/index.js",
    "dev": "tsx src/index.ts",
    "start": "node build/index.js",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src/",
    "lint:fix": "eslint src/ --fix",
    "format": "prettier --write \"src/**/*.ts\"",
    "format:check": "prettier --check \"src/**/*.ts\"",
    "prepublishOnly": "npm audit && npm run build"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/paifas/mcp-web-tools.git"
  },
  "homepage": "https://github.com/paifas/mcp-web-tools#readme",
  "bugs": {
    "url": "https://github.com/paifas/mcp-web-tools/issues"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "web-search",
    "tavily",
    "ai",
    "claude",
    "opencode"
  ],
  "license": "MIT",
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^25.5.2",
    "@vitest/coverage-v8": "^4.1.4",
    "eslint": "^10.2.0",
    "eslint-config-prettier": "^10.1.8",
    "prettier": "^3.8.1",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2",
    "typescript-eslint": "^8.58.1",
    "vitest": "^4.1.4"
  }
}
